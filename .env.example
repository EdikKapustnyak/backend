# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
# NOTE: Purchase completion uses a MongoDB transaction, which requires this
# to point at a replica set (a single-node one is fine for local dev/small
# deployments). MongoDB Atlas is a replica set by default. See README
# "Running MongoDB locally" for self-hosted setup.
MONGODB_URI=mongodb://localhost:27017/inventory_management?replicaSet=rs0

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Platform admin JWT - deliberately separate secrets from the tenant JWT_*
# pair above (see config/env.ts for why). Generate two more distinct
# 32+ char random strings, not reuses of the ones above.
ADMIN_JWT_ACCESS_SECRET=replace-with-a-third-long-random-secret-min-32-chars
ADMIN_JWT_ACCESS_EXPIRES_IN=15m
ADMIN_JWT_REFRESH_SECRET=replace-with-a-fourth-long-random-secret-min-32-chars
ADMIN_JWT_REFRESH_EXPIRES_IN=7d
ADMIN_REFRESH_COOKIE_NAME=adminRefreshToken

# Cookies
REFRESH_COOKIE_NAME=refreshToken
COOKIE_DOMAIN=localhost

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# How often (ms) the grace-period sweep job scans for PAST_DUE companies
# whose grace period has elapsed. Default: hourly.
GRACE_PERIOD_SWEEP_INTERVAL_MS=3600000

# Cloudflare R2 (S3-compatible object storage) - required for receipt photo
# uploads only. Create a bucket + API token in the Cloudflare dashboard
# (R2 > Manage API Tokens). Endpoint is derived from the account ID:
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Anthropic API - required for the AI assistant features (waste analysis
# narrative + recommendations, local events search). Get a key at
# https://console.anthropic.com/settings/keys - this is a separate,
# billed-by-usage API key, not your claude.ai login.
ANTHROPIC_API_KEY=

# Resend - required to actually deliver invite emails; if left empty, the
# invite endpoint still works but returns the accept-invite link directly
# in the API response instead of emailing it (see utils/mailer.ts).
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
MAIL_FROM=

# Base URL of the frontend - used to build the accept-invite link.
FRONTEND_URL=http://localhost:5173

# Stripe - required to process payments (checkout, portal, webhook). Get a
# secret key at https://dashboard.stripe.com/apikeys (use a test-mode key
# while developing) and a webhook signing secret from the endpoint you
# register at https://dashboard.stripe.com/webhooks (or via `stripe listen`
# locally). Left empty, checkout/portal/webhook simply don't work yet -
# nothing else in the app depends on this being set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# Swagger UI at GET /docs (+ raw spec at GET /docs/openapi.json). On by
# default everywhere except production - set to 'false' to force it off,
# or 'true' to force it on in production too. Leave empty for the default.
ENABLE_API_DOCS=
